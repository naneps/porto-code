# Google Gemini API — https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
VITE_GEMINI_API_KEY=your_vite_gemini_api_key_here

# Spotify — https://developer.spotify.com/dashboard
# Client Secret kept server-side only. Client ID is safe to expose in frontend.
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# Optional: Force a specific redirect URI (useful for local development)
# If not set, the app will use window.location.origin + '/'
# VITE_SPOTIFY_REDIRECT_URI=http://localhost:5173/
